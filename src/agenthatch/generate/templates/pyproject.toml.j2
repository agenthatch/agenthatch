[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[project]
name = "{{ agent_name }}-agent"
version = "{{ version }}"
description = "{{ description }}"
requires-python = ">=3.11"
dependencies = [
    "typer>=0.15.0",
    "rich>=13.0",
]

[tool.hatch.build.targets.wheel]
packages = ["src/{{ package_name }}"]