"""Local tool implementations for the {{ package_name }} agent.

This file implements native Python wrappers for all capabilities declared
in agenthatch.yaml. Each tool follows the same pattern:

1. For script-backed capabilities: wrap subprocess invocation
2. For MCP-backed capabilities: handled by MCP proxy (wrapper is placeholder)
3. For API templates: follow the API template definition
4. For native capabilities: direct implementation
5. For description-only capabilities: AI-generated or template fallback
"""
import json
import subprocess
from pathlib import Path
from typing import Any

# Path to the skills/scripts directory
SKILLS_SCRIPTS_DIR = Path(__file__).parent / "skills" / "scripts"

__all__: list[str] = [
{% for tool in tool_metadata %}
    "{{ tool.func_name }}",
{% endfor %}
]

{% for tool in tool_metadata %}

{% if tool.has_inputs %}
def {{ tool.func_name }}({% for param_name, param_type, default in tool.params %}{{ param_name }}: {{ param_type }} = {{ default }}{% if not loop.last %}, {% endif %}{% endfor %}) -> Any:
{% else %}
def {{ tool.func_name }}() -> Any:
{% endif %}
    """{{ tool.description }}
{% if tool.backend_kind == "script" %}
    Script-backed capability from skills/scripts/{{ tool.script_name }}.
    This wrapper executes the pre-existing script via subprocess.
{% endif %}
{% if tool.backend_kind == "mcp" %}
    MCP-backed capability via {{ tool.mcp_server }} server.
    This is a placeholder wrapper; the actual execution goes through MCP proxy.
{% endif %}
{% if tool.backend_kind == "api_template" %}
    API template capability. Follows the API template definition from the spec.
{% endif %}
{% if tool.backend_kind == "none" %}
    AI-generated implementation based on skill context.
{% endif %}
    """
{% if tool.func_name in ai_tool_impls %}
    # === AI-generated implementation ===
{{ ai_tool_impls[tool.func_name] }}
{% elif tool.backend_kind == "script" %}
    args = str(SKILLS_SCRIPTS_DIR / {{ tool.script_name_repr }}).split()
    {% for param_name, _, _ in tool.params %}
    args.append(str({{ param_name }}))
    {% endfor %}
    result = subprocess.run(
        args, capture_output=True, text=True, timeout=60,
    )
    if result.returncode != 0:
        return f"ERROR (exit {result.returncode}): {result.stderr.strip()}"
    return result.stdout.strip()
{% elif tool.backend_kind == "mcp" %}
    # MCP tools are handled via CapBus with MCPProxyExecutor
    # This function is not called directly
    return f"[MCP tool: {{ tool.name }}] processed by MCP server '{{ tool.mcp_server }}'"
{% elif tool.backend_kind == "api_template" %}
    # API template will be injected by the API template loader
    return f"[API template tool: {{ tool.name }}] - call this capability to execute"
{% else %}
    # v0.8.19: AI tool generation failed or was skipped.
    # The tool is a non-functional stub — the agent will see an error
    # message instead of hallucinating that the tool worked.
    _msg = (
        f"ERROR: Tool '{{ tool.name }}' is not implemented. "
        "AI tool generation did not produce a valid implementation. "
        "Re-run 'agenthatch hatch' with a working LLM provider, "
        "or implement this function manually."
    )
    return _msg
{% endif %}
{% endfor %}
{% if not tool_metadata %}
# No capabilities defined
{% endif %}
{% if mcp_servers %}
# ── v0.8.16: Self-configure MCP auth ────────────────────────────────

def configure_mcp_auth(server_name: str = "", auth_token: str = "") -> Any:
    """Write MCP auth token to ~/config/mcporter.json.

    Call this when the user provides credentials. The agent will
    automatically configure the MCP server and can then execute tools.
    """
    import json
    from pathlib import Path

    if not auth_token:
        return "Error: auth_token is required. Usage: configure_mcp_auth(auth_token='Bearer xxx')"

    config_dir = Path.home() / "config"
    config_file = config_dir / "mcporter.json"
    name = server_name or "{{ mcp_servers[0].name if mcp_servers else '' }}"

    # Read existing config or create
    config = {}
    if config_file.exists():
        try:
            config = json.loads(config_file.read_text(encoding="utf-8"))
        except (json.JSONDecodeError, Exception):
            pass

    # Ensure Bearer prefix
    token = auth_token if auth_token.startswith("Bearer ") else f"Bearer {auth_token}"

    config.setdefault("mcpServers", {}).setdefault(name, {}).setdefault("headers", {})["Authorization"] = token

    config_dir.mkdir(parents=True, exist_ok=True)
    config_file.write_text(json.dumps(config, indent=2, ensure_ascii=False), encoding="utf-8")

    return f"MCP auth configured for '{name}'. Tools should now work."
{% endif %}