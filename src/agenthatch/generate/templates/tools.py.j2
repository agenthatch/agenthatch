"""{{ agent_name }} domain tools.

Tools registered in agenthatch.yaml's interface.provides
are automatically wired by AHCoreAgent._build_runtime_tools().
Add custom implementations below or register via agent.tools=[my_func].
"""

{%- if tools %}
{% for tool in tools %}

def {{ tool }}(**kwargs) -> str:
    """Handle the '{{ tool }}' capability.

    Args are passed as keyword arguments matching the input_schema.
    Return a string result.
    """
    return f"{{ tool }} executed with {kwargs}"
{% endfor %}

{%- else %}
# No provides capabilities defined in the spec.
# Add custom tools here and pass them as tools=[my_func] to the Agent.

__all__: list[str] = []
{%- endif %}