# v0.7.6: CompiledWorkflow — structured step execution from agenthatch.yaml
from dataclasses import dataclass

@dataclass
class WorkflowStep:
    step: int
    description: str
    script: str | None = None

class CompiledWorkflow:
    """Compiled linear workflow from agenthatch.yaml instructions.

    Enforces step order sequentially. Steps with scripts are executed
    deterministically without LLM decision-making.
    """

    steps: list[WorkflowStep]
    _current_index: int = 0

    def __init__(self, steps: list[WorkflowStep]):
        self.steps = steps
        self._current_index = 0

    def next_step(self) -> WorkflowStep:
        """Get the next step in linear order."""
        step = self.steps[self._current_index]
        self._current_index += 1
        return step

    def is_complete(self) -> bool:
        return self._current_index >= len(self.steps)

