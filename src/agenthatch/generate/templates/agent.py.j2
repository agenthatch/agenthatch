    # ── MCP auto-configuration (v0.8.10, v0.8.13: self-writing) ────

    def _ensure_mcp_ready(self):
        """Auto-configure MCP runtime dependencies at startup.

        v0.8.13: Actually writes mcporter.json and exports env vars,
        instead of just telling the user to do it manually.
        """
        import shutil
        import subprocess
        import json
        import os
        from pathlib import Path

        spec = self._load_spec()
        if not spec:
            return

        # v0.8.19: mcp_servers is at top level of AHSSpec, not under "interface"
        mcp_servers = spec.get("mcp_servers", [])
        if not mcp_servers:
            return  # Not an MCP skill

        issues = []

        # 1. Check/install mcporter
        if not shutil.which("mcporter"):
            npm = shutil.which("npm")
            if npm:
                try:
                    subprocess.run(
                        [npm, "install", "-g", "mcporter"],
                        capture_output=True, timeout=30,
                    )
                except Exception:
                    pass
            if not shutil.which("mcporter"):
                issues.append(
                    "mcporter not installed. Run: npm install -g mcporter"
                )

        # 2. v0.8.13: Auto-write mcporter.json if missing
        if shutil.which("mcporter"):
            config_dir = Path.home() / "config"
            config_file = config_dir / "mcporter.json"

            # Check if MCP server is already configured
            mcp_name = mcp_servers[0].get("name", "")
            need_write = True
            if config_file.exists():
                try:
                    existing = json.loads(config_file.read_text(encoding="utf-8"))
                    if isinstance(existing, dict):
                        servers = existing.get("mcpServers", {})
                        if mcp_name in servers:
                            need_write = False  # Already configured
                except (json.JSONDecodeError, Exception):
                    pass

            if need_write:
                # Build the MCP server config from spec
                mcp_url = mcp_servers[0].get("url", "")
                headers = mcp_servers[0].get("headers", {}).copy()

                # Try to get auth token from environment
                env_vars = spec.get("base", {}).get("env", [])
                for ev in env_vars:
                    if isinstance(ev, dict):
                        env_name = ev.get("name", "")
                        if env_name:
                            token = os.environ.get(env_name) or os.environ.get(env_name.upper())
                            if token and "Authorization" not in headers:
                                headers["Authorization"] = f"Bearer {token}"

                server_entry = {"baseUrl": mcp_url}
                if headers:
                    server_entry["headers"] = headers

                # Read existing config or create new
                existing_config = {}
                if config_file.exists():
                    try:
                        existing_config = json.loads(config_file.read_text(encoding="utf-8"))
                        if not isinstance(existing_config, dict):
                            existing_config = {}
                    except (json.JSONDecodeError, Exception):
                        pass

                existing_config.setdefault("mcpServers", {})[mcp_name] = server_entry

                try:
                    config_dir.mkdir(parents=True, exist_ok=True)
                    config_file.write_text(
                        json.dumps(existing_config, indent=2, ensure_ascii=False),
                        encoding="utf-8",
                    )
                except Exception as e:
                    issues.append(f"Could not write mcporter config: {e}")

        # 3. Check environment credentials and try to auto-set
        env_vars = spec.get("base", {}).get("env", [])
        for ev in env_vars:
            if isinstance(ev, dict):
                name = ev.get("name", "")
                if name and not os.environ.get(name) and not os.environ.get(name.upper()):
                    issues.append(
                        f"Credential '{name}' not set. "
                        f"When the user provides a token, call "
                        f"configure_mcp_auth(auth_token='the_token_they_give_you'). "
                        f"I will configure it automatically."
                    )

        if issues:
            self.ctx.add_to_history(
                "system",
                "Auto-configuration notes:\n" + "\n".join(f"- {i}" for i in issues),
            )

    def _load_spec(self):
        """Load AHSSPEC from agenthatch.yaml."""
        try:
            spec_path = Path(__file__).parent.parent.parent / "agenthatch.yaml"
            if spec_path.exists():
                import yaml
                return yaml.safe_load(spec_path.read_text(encoding="utf-8"))
        except Exception:
            pass
        return None

    # ── Tool health check (v0.9) ─────────────────────────────────────

    def _check_tool_health(self):
        """Verify tooling is functional at startup.

        Checks required CLI dependencies from spec base.dependencies.
        Stores issues as instance attributes — does NOT inject into
        conversation context. Issues are surfaced only when a tool
        invocation actually fails, avoiding context bloat.
        """
        import shutil as _shutil
        import ast as _ast

        self._tool_health_issues: list[str] = []

        # Check CLI dependency availability
        spec = self._load_spec() or {}
        dependencies = spec.get("base", {}).get("dependencies", [])
        for dep in dependencies:
            if not _shutil.which(dep):
                self._tool_health_issues.append(
                    f"CLI dependency '{dep}' not found on PATH. "
                    f"Install it or run: agenthatch hatch"
                )

        # Check for stub tools (AI generation failures left unresolved)
        try:
            tools_path = Path(__file__).parent / "tools.py"
            if tools_path.exists():
                content = tools_path.read_text(encoding="utf-8")
                stub_sig = "AI tool generation did not produce a valid implementation"
                if stub_sig in content:
                    tree = _ast.parse(content)
                    stubs = [
                        node.name for node in _ast.walk(tree)
                        if isinstance(node, _ast.FunctionDef)
                        and _ast.get_source_segment(content, node)
                        and stub_sig in (_ast.get_source_segment(content, node) or "")
                    ]
                    if stubs:
                        self._tool_health_issues.append(
                            f"{len(stubs)} tools are non-functional stubs: "
                            f"{', '.join(stubs)}. "
                            f"Re-run 'agenthatch hatch' to regenerate, "
                            f"or implement them manually in tools.py."
                        )
        except Exception:
            pass

        # Do NOT inject into history — only surface on actual tool failure.
        # Runtime can check self._tool_health_issues when a tool returns an error.

        

    # ── Warmup scripts (run once at initialization) ────────────────────

    def _run_warmup_scripts(self):
        """Execute all workflow scripts once during initialization.

        Script results are recorded in system history for LLM context.
        Step descriptions remain in _workflow for conversational guidance.
        """
        if not self._workflow:
            return

        scripts_dir = Path(__file__).parent / "skills" / "scripts"
        if not scripts_dir.is_dir():
            return

        warmup_results = []

        for step in self._workflow.steps:
            if step.script is None:
                continue
            script_path = scripts_dir / step.script
            if not script_path.exists():
                warmup_results.append(
                    f"Step {step.step} ({step.description}) SKIPPED: script not found"
                )
                continue
            try:
                result = subprocess.run(
                    [sys.executable, str(script_path)],
                    capture_output=True, text=True, timeout=30,
                    cwd=str(scripts_dir),
                )
                warmup_results.append(
                    f"Step {step.step} ({step.description}): {result.stdout[:300]}"
                )
            except Exception as e:
                warmup_results.append(
                    f"Step {step.step} ({step.description}) FAILED: {e}"
                )

        if warmup_results:
            self.ctx.add_to_history(
                "system",
                "Warmup scripts completed:\n" + "\n".join(warmup_results),
            )

    # ── Pre-turn workflow (LLM always runs) ──────────────────────────

    def _pre_turn_workflow(self, user_input: str) -> str | None:
        """Inject current workflow step as context. LLM always runs."""
        if self._workflow is None or self._workflow.is_complete():
            return None

        step = self._workflow.next_step()
        self.ctx._workflow_note = (
            f"Current workflow step: {step.step} — {step.description}"
        )

        return None

    # ── chat / stream overrides for workflow integration ────────────────

    def chat(self, user_input: str) -> str:
        """Single-turn chat with workflow support."""
        self._pre_turn_workflow(user_input)
        return super().chat(user_input)

    def chat_stream(self, user_input: str):
        """Streaming chat with workflow support.

        v1.0.1 (R4-V23): ``return (yield from ...)`` propagates the
        subgenerator's return value (the final answer text).  Bare
        ``yield from`` discards it, so callers that rely on
        ``StopIteration.value`` see an empty response even though the
        real answer was streamed to the user.
        """
        self._pre_turn_workflow(user_input)
        return (yield from super().chat_stream(user_input))