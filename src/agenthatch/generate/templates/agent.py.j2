    # ── v0.7.6: Pre-turn workflow execution ──────────────────────────────

    def _pre_turn_workflow(self, user_input: str) -> str | None:
        """Run workflow step before the LLM turn.

        Returns script result if a deterministic script was executed,
        None otherwise (proceed to normal LLM turn).
        """
        if self._workflow is None or self._workflow.is_complete():
            return None

        step = self._workflow.next_step()
        # Inject step context into the next turn's system prompt
        self.ctx._workflow_note = (
            f"Current workflow step: {step.step} — {step.description}"
        )

        # If step has a script → execute deterministically, skip LLM
        if step.script is not None:
            result = self.sandbox.run(
                step.script,
                cwd=str(Path(__file__).parent.parent.parent / "skills" / "scripts"),
            )
            self.ctx.add_to_history(
                "system",
                f"Workflow step {step.step} completed: {result.stdout[:500]}",
            )
            return f"Executed workflow step {step.step}:\n{result.stdout}"

        # If step restricts tools → configure CapBus restriction
        if step.allowed_tools is not None:
            self._capbus_restricted = set(step.allowed_tools)

        return None  # Proceed to normal LLM turn

    # ── chat / stream overrides for workflow integration ────────────────

    def chat(self, user_input: str) -> str:
        """Single-turn chat with workflow support."""
        script_result = self._pre_turn_workflow(user_input)
        if script_result is not None:
            return script_result
        return super().chat(user_input)

    def chat_stream(self, user_input: str):
        """Streaming chat with workflow support."""
        script_result = self._pre_turn_workflow(user_input)
        if script_result is not None:
            yield script_result
            return script_result
        result = yield from super().chat_stream(user_input)
        return result